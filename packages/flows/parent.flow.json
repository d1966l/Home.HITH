{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
  "contentVersion": "1.1.0.0",
  "parameters": {},
  "triggers": {
    "When_a_file_is_created": {
      "type": "OpenApiConnectionWebhook",
      "inputs": {
        "host": {
          "connectionName": "shared_sharepointonline",
          "operationId": "OnNewFile",
          "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline"
        },
        "parameters": {
          "dataset": "@{environmentVariables('Env_SiteUrl')}",
          "folderId": "@{environmentVariables('Env_ScanningFolder')}"
        },
        "authentication": "@connection('shared_sharepointonline')"
      }
    }
  },
  "actions": {
    "Get_file_content": {
      "type": "OpenApiConnection",
      "inputs": {
        "host": {
          "connectionName": "shared_sharepointonline",
          "operationId": "GetFileContentUsingPath",
          "apiId": "/providers/Microsoft.PowerApps/apis/shared_sharepointonline"
        },
        "parameters": {
          "dataset": "@{environmentVariables('Env_SiteUrl')}",
          "path": "@{triggerOutputs()?['headers']['x-ms-file-path']}"
        },
        "authentication": "@connection('shared_sharepointonline')"
      }
    },
    "Run_Child_Flow": {
      "type": "OpenApiConnection",
      "runAfter": {
        "Get_file_content": [
          "Succeeded"
        ]
      },
      "inputs": {
        "host": {
          "connectionName": "shared_logicflows",
          "operationId": "FlowManagement-StartChildFlow",
          "apiId": "/providers/Microsoft.PowerApps/apis/shared_logicflows"
        },
        "parameters": {
          "childFlow": "HITH \u2013 Liaison Child Flow (v1.1)",
          "inputs": {
            "fileName": "@{triggerBody()?['{FilenameWithExtension}']}",
            "fileContentBase64": "@{base64(body('Get_file_content'))}",
            "docType": "@{if(contains(toLower(triggerBody()?['{FilenameWithExtension}']), 'cfs'), 'cfs', 'intake')}"
          }
        },
        "authentication": "@connection('shared_logicflows')"
      }
    }
  },
  "outputs": {}
}